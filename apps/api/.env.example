DATABASE_URL=postgresql://user:password@host:5432/adscreen
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d
PORT=3001

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=adscreen-media
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Pusher
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=mt1

# Redis
REDIS_URL=redis://localhost:6379

# Admin seed account (for seed:admin script)
ADMIN_EMAIL=admin@adscreen.io
ADMIN_PASSWORD=Admin1234!
ADMIN_DISPLAY_NAME=Platform Admin

# CORS
CORS_ORIGIN=http://localhost:3000
