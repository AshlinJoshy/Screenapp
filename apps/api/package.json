{
  "name": "@adscreen/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "seed:admin": "tsx src/scripts/seed-admin.ts"
  },
  "dependencies": {
    "@adscreen/db": "workspace:*",
    "@adscreen/types": "workspace:*",
    "@aws-sdk/client-s3": "^3.787.0",
    "@aws-sdk/s3-request-presigner": "^3.787.0",
    "@hono/node-server": "^1.14.4",
    "bcryptjs": "^3.0.2",
    "drizzle-orm": "^0.44.1",
    "hono": "^4.7.10",
    "jose": "^6.0.10",
    "postgres": "^3.4.7",
    "zod": "^3.24.2",
    "@hono/zod-validator": "^0.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.1.2"
  }
}
